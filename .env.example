# FlameGuardWeb Docker Compose configuration
# Copy this file to .env and adjust values for the target machine.

FLAMEGUARD_PORT=5000
FLAMEGUARD_ENV=production
TZ=Asia/Shanghai

# Front-end refresh interval in milliseconds. Recommended: 200-500 for demos.
FLAMEGUARD_REFRESH_MS=250

# Runtime dashboard history and response limits.
FLAMEGUARD_HISTORY_LIMIT=1800
FLAMEGUARD_DASHBOARD_DEFAULT_LIMIT=360
FLAMEGUARD_DASHBOARD_MAX_LIMIT=1200

# Keep production health checks strict: container becomes unhealthy if realtime
# NMPC fails to initialize and the app falls back to the phase-1 simulator.
# Set to 0 only when you intentionally want to allow the lightweight fallback.
FLAMEGUARD_HEALTH_REQUIRE_NMPC=1
